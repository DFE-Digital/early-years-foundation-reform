{
  "name": "eyfs-reform",
  "packageManager": "yarn@4.0.2",
  "scripts": {
    "build": "esbuild app/javascript/*.* --bundle --outdir=app/assets/builds",
    "build:css": "sass app/assets/stylesheets/application.scss app/assets/builds/application.css --no-source-map --load-path=node_modules --quiet-deps",
    "preinstall": "mkdir -p app/assets/builds public/govuk-assets/fonts public/govuk-assets/images",
    "postinstall": "cp -R node_modules/govuk-frontend/dist/govuk/assets/fonts/. public/govuk-assets/fonts && cp -R node_modules/govuk-frontend/dist/govuk/assets/images/. public/govuk-assets/images"
  },
  "resolutions": {
    "glob": "^10.5.0",
    "tar": "^7.5.11",
    "minimatch": "^10.2.3"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.1",
    "@hotwired/turbo-rails": "^8.0.21",
    "@stimulus-components/reveal": "^5.0.0",
    "dfe-frontend": "^2.0.1",
    "esbuild": "^0.27.3",
    "govuk-frontend": "^5.11.2",
    "sass": "^1.97.3"
  },
  "devDependencies": {
    "postcss": "8",
    "stylelint": "^16.26.1",
    "stylelint-config-gds": "^2.0.0"
  },
  "stylelint": {
    "extends": [
      "stylelint-config-gds/scss"
    ]
  }
}
